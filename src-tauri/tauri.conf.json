{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "网站分身管理器",
  "version": "0.1.0",
  "identifier": "com.codex.webclonemanager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "网站分身管理器",
        "width": 1600,
        "height": 980,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi"],
    "macOS": {
      "minimumSystemVersion": "14.0"
    }
  }
}
